# ── PostgreSQL Database (Required for Postgres, falls back to SQLite if empty) ──
# To enable PostgreSQL, fill all four variables. Leave empty to use SQLite.
MEDIFLOW_POSTGRES_HOST=localhost
MEDIFLOW_POSTGRES_DB=mediflow
MEDIFLOW_POSTGRES_USER=mediflow_user
MEDIFLOW_POSTGRES_PASSWORD=mediflow_password
MEDIFLOW_POSTGRES_HOST_PORT=5432

# ── LanguageTool Service Configuration ────────────────────────────────────────
MEDIFLOW_LANGUAGETOOL_URL=http://localhost:8010/v2/check
MEDIFLOW_LANGUAGETOOL_TIMEOUT_SECONDS=5.0

# ── AI Model Configuration ────────────────────────────────────────────────────
MEDIFLOW_LLM_PROVIDER=gemini
MEDIFLOW_LLM_MODEL=gemma-4-31b-it
MEDIFLOW_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_PROVIDER=ollama

# ── Gemini API Keys ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# ── API Endpoint URL ──────────────────────────────────────────────────────────
# Streamlit uses this URL to connect to the FastAPI backend service
MEDIFLOW_API_URL=http://localhost:8000
