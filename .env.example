# MediFlow v1.0 — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The Gemini API key can also be entered directly in the Streamlit UI at runtime.

# ── Gemini API Key ────────────────────────────────────────────────────────────
# Required for LLM generation and RAG summarization.
# Get your key at: https://aistudio.google.com/
# Optional: if left empty, you will be prompted to enter it in the Streamlit UI.
GEMINI_API_KEY=

# ── LLM Model ─────────────────────────────────────────────────────────────────
# Default Gemini/Gemma model to use (can be changed to any Gemini model)
MEDIFLOW_LLM_MODEL=gemma-4-31b-it

# ── RAG Embeddings ────────────────────────────────────────────────────────────
# Local HuggingFace embedding model (downloaded automatically on first run)
# No external service required.
RAG_EMBEDDING_PROVIDER=huggingface
MEDIFLOW_EMBEDDING_MODEL=BAAI/bge-small-en

# ── API Backend URL ───────────────────────────────────────────────────────────
# URL where the FastAPI backend is running. Only change if using a non-default port.
MEDIFLOW_API_URL=http://localhost:8000
